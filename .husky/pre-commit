#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running Universal Protocol Standard compliance check..."
node protocol-violation-scanner.js

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ CRITICAL HARDCODING VIOLATIONS DETECTED"
  echo "Commit blocked to prevent Universal Protocol Standard violations"
  echo "Please fix violations and try again"
  echo ""
  echo "Common fixes:"
  echo "• Replace Math.random() with UniversalAIConfig.generateUUID()"
  echo "• Replace Date.now() with UniversalAIConfig.generateTimestamp()"
  echo "• Replace direct API key access with DynamicAIConfig methods"
  echo "• Replace hardcoded timeouts with environment variables"
  echo ""
  exit 1
fi

echo "✅ Universal Protocol Standard compliance verified"