# Universal Protocol Standard Compliance - NO HARDCODED URLS
# All API URLs are configurable through environment variables

# AI Provider URLs (configurable, not hardcoded)
OPENAI_API_URL=https://api.openai.com
GEMINI_API_URL=https://generativelanguage.googleapis.com
ANTHROPIC_API_URL=https://api.anthropic.com

# File Upload Configuration (not hardcoded)
VITE_MAX_FILE_SIZE_MB=10

# UI Configuration (not hardcoded)
VITE_SIDEBAR_COOKIE_DAYS=7

# Database Configuration
DATABASE_URL=postgresql://...

# Encryption
AI_KEY_ENCRYPTION_SECRET=your-32-char-secret-key-here-123456

# Session Secret
SESSION_SECRET=your-session-secret-here