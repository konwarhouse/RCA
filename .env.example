# RCA Platform - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=rca_platform

# AI Provider Configuration (Optional - can be configured via Admin Panel)
# These are fallback values if database configuration is unavailable
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Application Configuration
NODE_ENV=development
REPLIT_DB_URL=your-replit-db-url-if-using-replit

# Security
SESSION_SECRET=your-secure-session-secret-here
JWT_SECRET=your-jwt-secret-for-authentication

# File Upload Configuration
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Purpose of each variable:
# DATABASE_URL: Primary database connection string for PostgreSQL
# PG* variables: Individual PostgreSQL connection parameters
# *_API_KEY: AI provider API keys for evidence analysis and RCA inference
# NODE_ENV: Environment mode (development/production)
# SESSION_SECRET: Used for secure session management
# JWT_SECRET: Used for authentication tokens
# MAX_FILE_SIZE_MB: Maximum file upload size for evidence files
# UPLOAD_DIR: Directory for storing uploaded evidence files